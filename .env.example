# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://clutch:clutch@localhost:5432/clutch

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars

# ─── API ────────────────────────────────────────────────────────────────────
PORT=3001

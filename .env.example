# ─── Prices ─────────────────────────────────────────────────────────────────
COINGECKO_API_KEY=

# ─── AI Agent (session 6+) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Vault encryption (session 4+) ─────────────────────────────────────────
VAULT_MASTER_KEY=

# ─── Database (Supabase) ───────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → Database → Connection string
# Use the "Transaction" pooler (port 6543) for API connections
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Use direct connection (port 5432) for migrations only
DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars

# ─── API ────────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ─── Blockchain RPCs ───────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ETHEREUM_RPC_URL=https://eth.llamarpc.com
BASE_RPC_URL=https://mainnet.base.org
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io

# ─── Prices ─────────────────────────────────────────────────────────────────
COINGECKO_API_KEY=

# ─── AI Agent (session 6+) ─────────────────────────────────────────────────
# Hugging Face Inference Providers token (used for Kimi K2)
# Get one at https://huggingface.co/settings/tokens — needs "Make calls to Inference Providers"

# Optional: override the LLM endpoint or model
# CLUTCH_LLM_BASE_URL=https://router.huggingface.co/v1
# CLUTCH_LLM_MODEL=moonshotai/Kimi-K2-Instruct-0905

# ─── Vault encryption (session 4+) ─────────────────────────────────────────
VAULT_MASTER_KEY=

# ─── WalletConnect (session 5+) ─────────────────────────────────────────
# Get from: https://cloud.walletconnect.com
WALLETCONNECT_PROJECT_ID=

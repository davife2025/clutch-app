{
  "name": "@clutch/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "echo 'using tsx — no build step'",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clutch/agent": "workspace:*",
    "@clutch/connectors": "workspace:*",
    "@clutch/core": "workspace:*",
    "@clutch/vault": "workspace:*",
    "@clutch/x402": "workspace:*",
    "@hono/node-server": "^2.0.1",
    "@hono/node-ws": "^1.3.0",
    "@solana/web3.js": "^1.98.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "bcryptjs": "^2.4.3",
    "bs58": "^6.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.30.4",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.4.0",
    "jsonwebtoken": "^9.0.2",
    "postgres": "^3.4.4",
    "tsx": "^4.21.0",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.4.0",
    "viem": "^2.48.4",
    "vitest": "^1.6.0",
    "zod": "^3.23.0"
  }
}
